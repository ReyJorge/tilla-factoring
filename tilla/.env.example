# --- TILLA lokální vývoj ---
# Zkopíruj jako `.env` ve stejném adresáři (`tilla/`). Soubor `.env` se necommituje.

# Session cookie (production: dlouhý náhodný řetězec).
SESSION_SECRET=zmen-me-v-produkci-nejmene-32-znaku

# Admin přihlášení (`admin` / toto heslo po seedu).
ADMIN_PASSWORD=changeme

# Credit Risk Agent + seed: pokud je email shodný s uživatelem v DB bez hesla,
# seed nastaví heslo na ADMIN_PASSWORD (např. mnovak@tilla.cz).
# OWNER_EMAIL=

# SQLite pokud DATABASE_URL není nastavená → data/tilla.db
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/tilla

ENVIRONMENT=development
DEBUG=1
SQL_ECHO=

# OpenAI (volitelné — bez klíče agent použije fallback bez LLM).
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Volitelné limity rule pre-checků (částky v Kč).
# CREDIT_RISK_SUPPLIER_CAP_CZK=
# CREDIT_RISK_ANCHOR_CAP_CZK=

# Nepouštět automatický demo seed při startu (Render / prázdná DB).
# TILLA_SKIP_AUTO_SEED=1
